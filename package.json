{
  "name": "react-dubside",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build:dev": "webpack  --env mode=development",
    "build:prod": "webpack --env mode=production",
    "prerender:gh": "TS_NODE_TRANSPILE_ONLY=1 ts-node src/scripts/prerender-gh.ts",
    "build:gh": "webpack --env mode=production publicPath=/dubside/",
    "build:gh:prerender": "yarn -s build:gh && yarn -s prerender:gh",
    "build:mobile": "webpack --env mode=production platform=mobile",
    "build:desktop": "webpack --env mode=production platform=desktop",
    "start": "webpack serve --env mode=development"
  },
  "author": "dunchek",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack": "^5.28.5",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@types/webpack-dev-server": "^4.7.2",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.3.0",
    "html-webpack-plugin": "^5.6.6",
    "jiti": "^2.6.1",
    "mini-css-extract-plugin": "^2.10.0",
    "react-refresh": "^0.18.0",
    "react-refresh-typescript": "^2.0.11",
    "react-router": "^7.13.0",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tslib": "^2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.2",
    "webpack-bundle-analyzer": "^5.2.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "colorthief": "^3.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
